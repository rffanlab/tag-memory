# ──────────────────────────────────────────────
# tag-memory configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# All variables use the TAG_MEMORY_ prefix to
# avoid collisions with other projects.
# ──────────────────────────────────────────────

# ── MySQL Connection ──────────────────────────
TAG_MEMORY_MYSQL_HOST=localhost
TAG_MEMORY_MYSQL_PORT=3306
TAG_MEMORY_MYSQL_USER=root
TAG_MEMORY_MYSQL_PASSWORD=
TAG_MEMORY_MYSQL_DATABASE=tag_memory

# ── LLM (OpenAI-compatible API) ───────────────
TAG_MEMORY_LLM_API_KEY=sk-your-key-here
TAG_MEMORY_LLM_BASE_URL=https://api.openai.com/v1
TAG_MEMORY_LLM_MODEL=gpt-4o-mini
